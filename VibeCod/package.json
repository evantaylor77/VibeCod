{
  "name": "vibecod",
  "version": "1.0.0",
  "description": "VibeCod - Ultimate Vibe Coding Assistant for Maximum Productivity",
  "main": "electron/main.js",
  "homepage": "./",
  "author": "evantaylor77",
  "repository": {
    "type": "git",
    "url": "https://github.com/evantaylor77/VibeCod.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run next:dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "next:dev": "next dev",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "build": "next build && npm run electron:build",
    "next:build": "next build",
    "electron:build": "electron-builder build --win --publish=never",
    "electron:build:portable": "electron-builder build --win portable",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "electron-store": "^10.0.0",
    "framer-motion": "^12.0.6",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.vibecod.app",
    "productName": "VibeCod",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VibeCod"
    }
  }
}